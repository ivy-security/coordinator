generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  meetings       Meeting[]      @relation("CreatedMeetings")
  availabilities Availability[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meeting {
  id                String        @id @default(cuid())
  title             String
  description       String?       @db.Text
  duration          Int
  status            MeetingStatus @default(ACTIVE)
  shareToken        String        @unique
  additionalContext String?       @db.Text
  linkedInUrl       String?
  imageUrl          String?
  creatorId         String
  creator           User          @relation("CreatedMeetings", fields: [creatorId], references: [id])
  timeOptions       TimeOption[]
  participants      Participant[]
  finalizedStart    DateTime?
  finalizedEnd      DateTime?
  finalizedAttendees String[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum MeetingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DISMISSED
}

model TimeOption {
  id             String         @id @default(cuid())
  meetingId      String
  meeting        Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  startTime      DateTime
  endTime        DateTime
  availabilities Availability[]
}

model Participant {
  id        String          @id @default(cuid())
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  email     String
  type      ParticipantType
  hasVoted  Boolean         @default(false)

  @@unique([meetingId, email])
}

enum ParticipantType {
  REQUIRED
  OPTIONAL
}

model Availability {
  id      String     @id @default(cuid())
  userId  String
  user    User       @relation(fields: [userId], references: [id])
  rangeId String
  range   TimeOption @relation(fields: [rangeId], references: [id], onDelete: Cascade)
  slots   DateTime[]

  @@unique([userId, rangeId])
}
